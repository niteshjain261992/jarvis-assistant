# Runtime environment: development | production | test
NODE_ENV=development

# HTTP port the server listens on
PORT=3000

# Base URL of the local Ollama instance
OLLAMA_BASE_URL=http://localhost:11434

# Ollama model used for command interpretation
OLLAMA_MODEL=llama3.1:8b

# Logging verbosity: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# MongoDB connection string and database name
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DATABASE=jarvis

# Required for server-side web search (Tavily API)
TAVILY_API_KEY=

# Qdrant vector store (for RAG write path)
QDRANT_URL=http://localhost:6333

# Ollama embedding model (nomic-embed-text, 768 dimensions)
EMBEDDING_MODEL=nomic-embed-text

# Nominatim reverse-geocoding base URL (keyless; override for testing)
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# Play music platform API credentials (optional until resolver is used)
# YOUTUBE_API_KEY=
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=
