{
  "name": "jarvis-backend",
  "version": "0.1.0",
  "description": "Jarvis backend - Express + TypeScript service",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "LOG_LEVEL=debug tsx watch src/server.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/server.js",
    "test": "TdAVILY_API_KEY=test-key NODE_ENV=test LOG_LEVEL=fatal jest --coverage",
    "lint": "eslint src tests",
    "format": "prettier --write \"src/**/*.ts\"",
    "prototype:agent": "tsx scripts/prototype-agent.ts"
  },
  "dependencies": {
    "@agendajs/mongo-backend": "^4.0.2",
    "@langchain/core": "^1.1.49",
    "@langchain/langgraph": "^1.4.2",
    "@langchain/ollama": "^1.2.7",
    "@langchain/qdrant": "^1.0.3",
    "@qdrant/js-client-rest": "^1.18.0",
    "@tavily/core": "^0.7.6",
    "agenda": "^6.2.5",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "helmet": "^8.2.0",
    "langchain": "^1.4.5",
    "mongoose": "^8.19.1",
    "pino": "^10.3.1",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.2",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.18.1",
    "eslint": "^10.4.1",
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.2.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "tsc-alias": "^1.8.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
